# Database MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT - usa una stringa lunga e casuale (es. openssl rand -hex 64)
JWT_SECRET=inserisci_una_stringa_segreta_lunga

# CORS - origini permesse (separate da virgola)
ALLOWED_ORIGINS=https://piccardo-design.vercel.app,http://localhost:5173

# Porta del server (opzionale, default 5000)
PORT=5000
